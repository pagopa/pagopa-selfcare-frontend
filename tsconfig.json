{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": [
      "es6",
      "dom",
      "es2019"
    ],
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noImplicitReturns": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@pagopa/selfcare-common-frontend/components/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/components/*"
      ],
      "@pagopa/selfcare-common-frontend/config/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/config/*"
      ],
      "@pagopa/selfcare-common-frontend/decorators/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/decorators/*"
      ],
      "@pagopa/selfcare-common-frontend/hooks/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/hooks/*"
      ],
      "@pagopa/selfcare-common-frontend/locale/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/locale/*"
      ],
      "@pagopa/selfcare-common-frontend/model/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/model/*"
      ],
      "@pagopa/selfcare-common-frontend/redux/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/redux/*"
      ],
      "@pagopa/selfcare-common-frontend/services/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/services/*"
      ],
      "@pagopa/selfcare-common-frontend/utils/*": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/utils/*"
      ],
      "@pagopa/selfcare-common-frontend/consentManagementConfigure": [
        "node_modules/@pagopa/selfcare-common-frontend/lib/consentManagementConfigure"
      ]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "allowSyntheticDefaultImports": true,
    "preserveConstEnums": true,
    "allowJs": false,
    "noUnusedParameters": false,
    "strictFunctionTypes": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "vite.config.mts"
  ],
  "exclude": [
    "**/__mocks__/**",
    "dist",
    "node_modules",
    "**/__tests__/*",
    "Dangerfile.ts",
    "integration-test"
  ]
}
